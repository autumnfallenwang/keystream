{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/region_picker", "sidecar": true, "args": true },
        { "name": "binaries/ocr_helper", "sidecar": true, "args": true }
      ]
    }
  ]
}
