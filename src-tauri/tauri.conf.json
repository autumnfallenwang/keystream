{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Keystream",
  "version": "0.1.3",
  "identifier": "dev.autumnfallenwang.keystream",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Keystream",
        "width": 900,
        "height": 700,
        "minWidth": 900,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCMTg4NjRDRDUyREZFRDAKUldUUS9pM1ZUSVlZMjg5cEw3V014Wmtlckl2QjdSUFZXYWozL3ptbTlZbUNyTXVHVk9vRXVidFIK",
      "endpoints": [
        "https://github.com/autumnfallenwang/keystream/releases/latest/download/latest.json"
      ]
    }
  }
}
