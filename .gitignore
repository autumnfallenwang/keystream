# ---------- Node / npm / pnpm / yarn ----------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm/
.eslintcache

# ---------- Next.js ----------
.next/
out/
next-env.d.ts

# ---------- TypeScript build output ----------
dist/
build/
*.tsbuildinfo

# ---------- Rust / Cargo / Tauri ----------
target/
**/target/
*.rs.bk
Cargo.lock.bak
src-tauri/target/
src-tauri/gen/schemas/
src-tauri/WixTools/

# PoC reference crate intentionally has no committed lockfile (see its
# README). Ignore the one cargo generates during local sanity builds.
docs/poc/typer/Cargo.lock

# ---------- Tauri bundler output ----------
src-tauri/target/release/bundle/

# Release artifacts downloaded to the repo root for local testing — never
# commit shippable binaries to source.
/*.dmg
/*.AppImage
/*.deb
/*.exe
/*.app.tar.gz
/*.sig
/latest.json

# ---------- Environment & secrets ----------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.keystore

# Tauri updater signing keys — never commit the private key
tauri-updater.key
tauri-updater.key.pub
!tauri-updater.pub

# ---------- App data / local databases ----------
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite3-journal
logs/
*.log

# ---------- Sandbox: POCs, live-credential smoke tests, spikes ----------
# Anything that exercises real AVD sessions or captures live screenshots lives
# here and is NEVER committed. See CLAUDE.md "Security constraints" section.
sandbox/

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- Editors / IDEs ----------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---------- Claude Code runtime state ----------
.claude/scheduled_tasks.lock

